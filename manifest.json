{
	"name": "Chroplus",
	"manifest_version": 3,
	"version": "1.0",
	"description": "plus and substract for more peace and quite",
	"permissions": ["sidePanel", "storage"],
	"side_panel": {
		"default_path": "sidepanel.html"
	},
	"action": {
		"default_icon": "icon.png",
		"default_title": "Chroplus AI Chat"
	},
	"background": {
		"service_worker": "background.js"
	},
	"content_scripts": [
		{
			"matches": ["http://acm.hdu.edu.cn/*"],
			"js":["chroplus.js"]
		},
		{
			"matches": ["https://www.baidu.com/*"],
			"js":["baidu.js"]
		},
		{
			"matches": ["https://www.jianshu.com/*"],
			"js":["jianshu.js"]
		},
		{
			"matches": ["http://blog.sina.com.cn/u/6274555375"],
			"js":["sinablog.js"]
		}
	]
}